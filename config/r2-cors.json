{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:3000",
          "http://localhost:3001",
          "https://likeability.fyi",
          "https://likeability.vercel.app",
          "https://*.vercel.app"
        ],
        "methods": ["GET", "PUT", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
